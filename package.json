{
  "name": "@djie/eslint-config",
  "type": "module",
  "version": "4.0.1",
  "description": "Anthony's ESLint config",
  "author": "(https://github.com/laihaojie/)",
  "license": "MIT",
  "homepage": "https://github.com/laihaojie/eslint-config",
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "verify-build": "node scripts/verify-build.mjs",
    "stub": "tsup --format esm",
    "dev": "tsdown --watch",
    "lint": "eslint",
    "prepack": "nr build",
    "release": "bumpp && pnpm publish --registry=https://registry.npmjs.org/ --no-git-checks",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "eslint": ">=8.40.0"
  },
  "dependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@antfu/eslint-define-config": "1.23.0-2"
  },
  "devDependencies": {
    "@antfu/ni": "^30.1.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.9.1",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "lint-staged": "^17.0.7",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
